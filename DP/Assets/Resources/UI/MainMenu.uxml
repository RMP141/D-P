<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements">
  <ui:VisualElement name="menu-container" style="flex-grow: 1; justify-content: center; align-items: center; background-color: rgba(0, 0, 0, 0.92);">
    <ui:Label text="CONVOY MANAGER" style="font-size: 36px; color: rgb(200, 200, 200); -unity-font-style: bold; -unity-text-align: middle-center; margin-bottom: 40px;" />
    <ui:Button name="continue-btn" text="Continue" style="width: 220px; height: 50px; font-size: 18px; margin-bottom: 10px;" />
    <ui:Button name="new-game-btn" text="New Game" style="width: 220px; height: 50px; font-size: 18px; margin-top: 5px;" />
    <ui:Button name="load-game-btn" text="Load Game" style="width: 220px; height: 50px; font-size: 18px; margin-top: 10px;" />
    <ui:Button name="quit-btn" text="Quit" style="width: 220px; height: 50px; font-size: 18px; margin-top: 30px;" />
  </ui:VisualElement>
</ui:UXML>
