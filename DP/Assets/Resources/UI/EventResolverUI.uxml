<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements">
  <ui:VisualElement style="flex-grow: 1; padding: 20px; background-color: rgba(0, 0, 0, 0.8);">
    <ui:VisualElement style="background-color: rgb(40, 40, 40); padding: 20px; border-color: rgb(100, 100, 100); border-width: 2px;">
      <ui:Label name="title" text="Event Title" style="font-size: 22px; -unity-font-style: bold; margin-bottom: 10px;" />
      <ui:Label name="description" text="Event description..." style="font-size: 14px; white-space: normal; margin-bottom: 15px;" />
      <ui:VisualElement name="buttons" style="flex-direction: row; justify-content: center;" />
    </ui:VisualElement>
  </ui:VisualElement>
</ui:UXML>
